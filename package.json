{
  "name": "lamma-arabic-chat-room",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-pwa-version.mjs && node scripts/sync-sitemap.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.strict-lib.json && eslint src --quiet",
    "lint:eslint": "eslint src",
    "verify:hardening": "node scripts/verify-production-hardening.mjs",
    "verify:live": "node scripts/verify-live-health.mjs",
    "verify:smoke": "node scripts/verify-smoke-e2e.mjs",
    "verify:all": "npm run lint && npm run build && npm run verify:hardening && npm run verify:live && npm run verify:smoke"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.14.3",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/wasm-node": "^4.61.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "rollup": "npm:@rollup/wasm-node",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3"
  }
}
