# Legacy AI Studio variable. Not required for the current local web app flow.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public app URL used by the deployed auth config endpoint and callback helpers.
# For local development, keep it aligned with the Vite dev server URL.
VITE_APP_URL="http://localhost:5173"

# PWA / Service Worker
# Disabled by default to avoid stale cached bundles after deploys.
# Set to "true" only when you intentionally want offline install/caching behavior.
VITE_ENABLE_PWA="false"

# Supabase Configuration
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Gemini Search API endpoint (اختياري — يستخدم في بحث شات لمة الذكي)
# اتركه فارغاً لو مش محتاج ميزة البحث داخل الشات
VITE_GEMINI_SEARCH_ENDPOINT=""

# Branding (optional)
VITE_BRAND_NAME="YOUR_BRAND_NAME"
VITE_BRAND_CREDIT="YOUR_BRAND_CREDIT"
VITE_LOGIN_HERO_BG="/images/login-hero.jpg"
