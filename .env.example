# Public app URL — used by auth callbacks (Supabase OAuth redirect)
# Local:  http://localhost:5173
# Prod:   https://lamma-arabic-chat-room.vercel.app
VITE_APP_URL="http://localhost:5173"

# PWA / Service Worker
# Disabled locally to avoid stale cached bundles after deploys.
# Production: Vercel sets VITE_ENABLE_PWA=true via vercel.json build.env
VITE_ENABLE_PWA="false"

# Supabase (required for auth, chat, media, realtime)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional — local scripts only (never commit a real token):
# SUPABASE_ACCESS_TOKEN="sbp_..."

# Server-only secrets (Vercel → Environment Variables — NEVER prefix with VITE_)
# GEMINI_API_KEY="..."
# SUPABASE_SERVICE_ROLE_KEY="..."
# OPS_BOOTSTRAP_SECRET="strong-random-secret"
# OWNER_EMAIL="owner@example.com"
# SUPABASE_ANON_KEY="..."  # optional duplicate for /api JWT verification

# Gemini Search API endpoint (optional — smart search in chat)
VITE_GEMINI_SEARCH_ENDPOINT=""

# Branding (optional)
VITE_BRAND_NAME="Lamma Chat"
VITE_BRAND_CREDIT="Your Name"
VITE_LOGIN_HERO_BG="/images/login-hero.jpg"

# WebRTC — مجاني: Open Relay (مضبوط على Vercel Production)
# لأعلى جودة مجانية: coturn على Oracle Always Free — راجع docs/FREE_CALLS_AR.md
# VITE_TURN_URL="turn:openrelay.metered.ca:443,turn:openrelay.metered.ca:80"
# VITE_TURN_USERNAME="openrelayproject"
# VITE_TURN_CREDENTIAL="openrelayproject"
